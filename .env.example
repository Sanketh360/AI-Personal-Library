# Gemini API key (Required for ADK reasoning)
# Create an API Key at https://aistudio.google.com/ and paste it below
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL= GEMINI_MODEL

# Directory and Database Paths
SQLITE_DB_PATH=./database/library.db
CHROMA_DB_PATH=./chroma_db
BOOKS_DIR=./books
UPLOADS_DIR=./uploads

# Model Configuration
EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
HF_HOME=./hf_cache

# CPU Performance Optimization (for 8GB RAM)
# Set to 'true' to completely disable reranker (makes responses instant: < 1.5s)
DISABLE_RERANKER=true
# Number of chunks to evaluate in reranker (lower = faster, e.g. 6 or 8)
RERANKER_CANDIDATE_LIMIT=8

# Hardware & API settings
PORT=8000
HOST=0.0.0.0
